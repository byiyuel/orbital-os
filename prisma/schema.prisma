generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Country {
  id          String             @id @default(cuid())
  code        String             @unique
  name        String
  region      String?
  incomeGroup String?
  snapshots   EconomicSnapshot[]
  favorites   UserFavorite[]
}

model EconomicSnapshot {
  id           String   @id @default(cuid())
  countryCode  String
  country      Country  @relation(fields: [countryCode], references: [code], onDelete: Cascade)
  year         Int
  gdp          Float?
  gdpGrowth    Float?
  inflation    Float?
  debtToGdp    Float?
  unemployment Float?
  createdAt    DateTime @default(now())

  @@index([countryCode, year])
}

model UserFavorite {
  id          String   @id @default(cuid())
  sessionId   String
  countryCode String
  country     Country  @relation(fields: [countryCode], references: [code], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([sessionId])
}
